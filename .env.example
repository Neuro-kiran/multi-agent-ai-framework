# Application Configuration
APP_NAME=multi-agent-ai-framework
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# LLM & API Keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/multi_agent_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Vector Store Configuration
VECTOR_DB_URL=postgresql://user:password@localhost:5432/vector_db
VECTOR_DIMENSION=1536

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Agent Configuration
MAX_AGENTS=10
AGENT_TIMEOUT=300
WORKFLOW_TIMEOUT=600

# Memory Configuration
MEMORY_TYPE=semantic
MEMORY_CAPACITY=10000
SEMANTIC_THRESHOLD=0.7

# Tool Configuration
TOOL_EXECUTION_TIMEOUT=30
TOOL_RETRY_ATTEMPTS=3
TOOL_RETRY_DELAY=1

# Security
SECRET_KEY=your-secret-key-for-jwt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Monitoring & Logging
SENTRY_DSN=
TRACE_ENABLED=false
TRACE_ENDPOINT=http://localhost:4317

# Feature Flags
ENABLE_PERSISTENCE=true
ENABLE_ASYNC_EXECUTION=true
ENABLE_TOOL_DISCOVERY=true
